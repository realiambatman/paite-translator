# Optional — only needed for private/gated models
HF_TOKEN=

# Hugging Face model repo (default: sensix-zo/nllb-paite-600m-v15)
MODEL_REPO=sensix-zo/nllb-paite-600m-v15

# Inference tuning (CPU defaults: 1 beam, batch 1 — faster on VPS)
# NUM_BEAMS=5
# CPU_BATCH_SIZE=1
# GPU_BATCH_SIZE=8

# Google Cloud Translation API key (server-side only — never expose in frontend)
GOOGLE_TRANSLATE_API_KEY=

# Max input size (~100 tokens default; one sentence only)
MAX_TRANSLATION_TOKENS=100

# Server
PORT=8000
CORS_ORIGINS=*

# Frontend build output path (set automatically in Docker)
STATIC_DIR=
