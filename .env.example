# Optional — only needed for private/gated models
HF_TOKEN=

# Hugging Face model repo (PyTorch fallback)
MODEL_REPO=sensix-zo/nllb-paite-600m-v15

# CTranslate2 — faster CPU inference (upload converted model to HF once)
INFERENCE_BACKEND=ctranslate2
CT2_MODEL_REPO=sensix-zo/nllb-paite-600m-v15-ct2
CT2_COMPUTE_TYPE=int8

# Inference tuning (CPU defaults: 1 beam, batch 1 — faster on VPS)
# NUM_BEAMS=5
# CPU_BATCH_SIZE=1
# GPU_BATCH_SIZE=8

# Re-run a tiny translation every N seconds so the OS does not swap model
# weights to disk after idle (set 0 to disable). Default: 300 (5 min).
# KEEP_WARM_INTERVAL_SEC=300

# Retry decoding when output is almost identical to English input (Paite route).
# COPY_THROUGH_RATIO=0.80
# COPY_THROUGH_RETRY_BEAMS=8

# Google Cloud Translation API key (server-side only)
GOOGLE_TRANSLATE_API_KEY=

# App-side daily Google character cap (independent of GCP console quota)
# 16000 ≈ under 500k/month free tier. Use 0 or unlimited to disable app cap.
GOOGLE_DAILY_CHAR_LIMIT=16000

# Max input size (~200 tokens / ~800 characters)
MAX_TRANSLATION_TOKENS=200

# Server
PORT=8000
CORS_ORIGINS=*
STATIC_DIR=/app/static

# Unique per deploy — busts cached JS on mobile after rebuilds.
# Coolify: set BUILD_ID=${SOURCE_COMMIT} as a Docker build arg.
BUILD_ID=

# Firebase web config — baked into frontend at Docker BUILD (Coolify env vars)
# Get these from Firebase Console → Project settings → General → Your apps → Web
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_TRANSLATIONS_COLLECTION=translations
VITE_FIREBASE_GOOGLE_QUOTA_COLLECTION=google_translate_quota
